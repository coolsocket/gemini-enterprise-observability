# Copy to `.env` and edit. Makefile auto-includes .env and exports every
# variable, so once this file is filled in you can run any make target
# without prefixing (`make serve`, `make deploy-infra`, `make resume`, …).
# .env itself is gitignored — don't commit real project IDs / paths.

# ============================================================
# Required
# ============================================================

# Your GCP project ID (the GE deployment you want to observe).
BQ_PROJECT=my-project

# Also aliased as PROJECT for Makefile deploy targets — must match BQ_PROJECT.
PROJECT=my-project

# ============================================================
# Optional — defaults shown
# ============================================================

# BigQuery dataset the log-sink writes into (created by terraform).
BQ_DATASET=ge_observability
DATASET=ge_observability

# GCP region for Cloud Run + Artifact Registry. Common alternates:
# asia-southeast1 (Singapore), europe-west1 (Belgium), asia-east1 (Taiwan).
REGION=us-central1

# BigQuery dataset location. Match REGION unless you deliberately want
# data-residency separation (preflight will hard-block on mismatch —
# set ALLOW_REGION_MISMATCH=y if intentional).
BQ_LOCATION=US

# Prefix stripped from principal emails at query time so seed/simulated
# service accounts display as generic actors. Leave as `sim-` unless
# your seed SAs use another convention (e.g. `demo-`).
SIM_PREFIX=sim-

# Uvicorn port for `make serve` / `make api-run`.
PORT=8000

# ============================================================
# Authentication (typically set from your shell, not .env)
# ============================================================

# ADC credentials for Python + FastAPI. If unset, google.auth.default()
# falls back to ~/.config/gcloud/application_default_credentials.json
# (populated by `gcloud auth application-default login`).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

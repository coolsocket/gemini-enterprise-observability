-- ---------------------------------------------------------------
-- v_admin_activity — Path 3 admin operations
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_admin_activity` AS
WITH base AS (
  SELECT
    timestamp,
    REGEXP_REPLACE(protopayload_auditlog.authenticationInfo.principalEmail, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(protopayload_auditlog.methodName, r'\.([^.]+)$') AS action,
    REGEXP_EXTRACT(protopayload_auditlog.methodName, r'\.([^.]+Service)\.') AS service,
    REGEXP_EXTRACT(protopayload_auditlog.resourceName, r'/([a-zA-Z]+)/[^/]+$') AS resource_type,
    REGEXP_EXTRACT(protopayload_auditlog.resourceName, r'/[^/]+/([^/]+)$') AS resource_id,
    REGEXP_EXTRACT(protopayload_auditlog.resourceName, r'/engines/([^/]+)') AS engine_id_raw,
    protopayload_auditlog.resourceName AS full_resource,
    protopayload_auditlog.methodName AS full_method,
    protopayload_auditlog.requestMetadata.callerIp AS caller_ip,
    receiveTimestamp
  FROM `{{PROJECT}}.{{DATASET}}.cloudaudit_googleapis_com_activity`
  WHERE (protopayload_auditlog.methodName LIKE '%discoveryengine%'
      OR protopayload_auditlog.methodName LIKE '%notebooklm%')
)
SELECT
  b.*,
  CASE
    WHEN b.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN b.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN b.actor_email LIKE '%@%' AND b.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    WHEN b.actor_email IS NULL OR b.actor_email = '' THEN 'UNKNOWN'
    ELSE 'HUMAN'
  END AS origin,
  em.display_name AS engine_display_name
FROM base b
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em
  ON b.engine_id_raw = em.engine_id;

-- ---------------------------------------------------------------
-- v_builders — admin operation leaderboard
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_builders` AS
SELECT
  actor_email,
  CASE
    WHEN actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN actor_email LIKE '%@%' AND actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  COUNTIF(full_method LIKE '%CreateAgent') AS agents_created,
  COUNTIF(full_method LIKE '%DeleteAgent') AS agents_deleted,
  COUNTIF(full_method LIKE '%CreateEngine') AS engines_created,
  COUNTIF(full_method LIKE '%DeleteEngine') AS engines_deleted,
  COUNTIF(full_method LIKE '%CreateDataStore') AS datastores_created,
  COUNTIF(full_method LIKE '%DeleteDataStore') AS datastores_deleted,
  COUNTIF(full_method LIKE '%Update%') AS update_actions,
  COUNT(*) AS total_admin_actions,
  MIN(timestamp) AS first_admin_action,
  MAX(timestamp) AS last_admin_action
FROM `{{PROJECT}}.{{DATASET}}.v_admin_activity`
WHERE actor_email IS NOT NULL
GROUP BY actor_email, origin;

-- ---------------------------------------------------------------
-- v_data_access — Path 3 reads
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_data_access` AS
WITH base AS (
  SELECT
    timestamp,
    REGEXP_REPLACE(protopayload_auditlog.authenticationInfo.principalEmail, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(protopayload_auditlog.methodName, r'\.([^.]+)$') AS action,
    REGEXP_EXTRACT(protopayload_auditlog.methodName, r'\.([^.]+Service)\.') AS service,
    REGEXP_EXTRACT(protopayload_auditlog.resourceName, r'/engines/([^/]+)') AS engine_id_raw,
    REGEXP_EXTRACT(protopayload_auditlog.resourceName, r'/dataStores/([^/]+)') AS datastore_id,
    protopayload_auditlog.resourceName AS full_resource,
    protopayload_auditlog.methodName AS full_method,
    protopayload_auditlog.requestMetadata.callerIp AS caller_ip
  FROM `{{PROJECT}}.{{DATASET}}.cloudaudit_googleapis_com_data_access`
  WHERE (protopayload_auditlog.methodName LIKE '%discoveryengine%'
      OR protopayload_auditlog.methodName LIKE '%notebooklm%')
)
SELECT
  b.*,
  CASE
    WHEN b.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN b.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN b.actor_email LIKE '%@%' AND b.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    WHEN b.actor_email IS NULL OR b.actor_email = '' THEN 'UNKNOWN'
    ELSE 'HUMAN'
  END AS origin,
  em.display_name AS engine_display_name
FROM base b
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em
  ON b.engine_id_raw = em.engine_id;

-- ---------------------------------------------------------------
-- v_data_access_summary — bucketed by real GE method dictionary
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_data_access_summary` AS
SELECT
  actor_email,
  CASE
    WHEN actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN actor_email LIKE '%@%' AND actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  engine_id_raw AS engine_id,
  engine_display_name,
  COUNTIF(full_method LIKE '%AssistantService.StreamAssist'
       OR full_method LIKE '%AssistantService.Assist') AS chat_turns,
  COUNTIF(full_method LIKE '%AssistantService.AsyncAssist'
       OR full_method LIKE '%AssistantService.ReadAsyncAssist') AS deep_research_calls,
  -- NotebookLM (real method namespace is v1main, NOT v1alpha. Catches both for safety.)
  -- NotebookService: CreateNotebook, GetNotebook, GenerateNotebookGuide, DiscoverSources, etc.
  -- AccountService: GetOrCreateAccount (per-user NotebookLM identity setup)
  COUNTIF(full_method LIKE '%notebooklm.v1main.NotebookService.%'
       OR full_method LIKE '%notebooklm.v1alpha.NotebookService.%'
       OR full_method LIKE '%notebooklm.v1main.AccountService.%') AS notebooklm_notebook_ops,
  -- SourceService: BatchCreateSources, GetSource. NoteService: BatchGetNotes.
  -- ArtifactService: ListArtifacts, CreateArtifact (generated mind maps, briefs, etc.)
  COUNTIF(full_method LIKE '%notebooklm.v1main.SourceService.%'
       OR full_method LIKE '%notebooklm.v1alpha.SourceService.%'
       OR full_method LIKE '%notebooklm.v1main.NoteService.%'
       OR full_method LIKE '%notebooklm.v1main.ArtifactService.%') AS notebooklm_content_ops,
  -- AudioOverviewService: podcast-style audio generated from notebook
  COUNTIF(full_method LIKE '%notebooklm.v1main.AudioOverviewService.%'
       OR full_method LIKE '%notebooklm.v1alpha.AudioOverviewService.%') AS notebooklm_audio_ops,
  -- A2A agent invocation (marketplace agents + custom agents via A2A protocol)
  COUNTIF(full_method LIKE '%assistants.agents.a2a.v1.message.%'
       OR full_method LIKE '%assistants.agents.a2a.v1.tasks.%') AS a2a_invocations,
  COUNTIF(full_method LIKE '%CompletionService.%Complete%') AS autocomplete_calls,
  COUNTIF(full_method LIKE '%ConversationalSearchService.%') AS session_ops,
  COUNTIF(full_method LIKE '%UserEventService.%') AS feedback_events,
  COUNTIF(full_method LIKE '%SearchService.Search') AS programmatic_searches,
  COUNTIF(full_method LIKE '%ListSessionFileMetadata'
       OR full_method LIKE '%DownloadSessionFile') AS session_files,
  COUNTIF(full_method LIKE '%CannedQueryService.%') AS canned_queries,
  COUNTIF(full_method NOT LIKE '%AssistantService.%'
      AND full_method NOT LIKE '%CompletionService.%'
      AND full_method NOT LIKE '%ConversationalSearchService.%'
      AND full_method NOT LIKE '%UserEventService.%'
      AND full_method NOT LIKE '%SearchService.%'
      AND full_method NOT LIKE '%CannedQueryService.%'
      AND full_method NOT LIKE '%notebooklm.%'
      AND full_method NOT LIKE '%assistants.agents.a2a.v1.%') AS other,
  COUNT(*) AS total_data_access,
  MIN(timestamp) AS first_access,
  MAX(timestamp) AS last_access
FROM `{{PROJECT}}.{{DATASET}}.v_data_access`
WHERE actor_email IS NOT NULL
GROUP BY actor_email, engine_id_raw, engine_display_name
ORDER BY total_data_access DESC;

-- ---------------------------------------------------------------
-- v_conversations — prompt with PII redaction
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_conversations` AS
WITH base AS (
  SELECT
    timestamp,
    trace AS trace_id,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(jsonPayload.logmetadata.name, r'/engines/([^/]+)') AS engine_id_raw,
    (SELECT text FROM UNNEST(jsonPayload.request.query.parts) WHERE text IS NOT NULL LIMIT 1) AS prompt_raw,
    REGEXP_EXTRACT(jsonPayload.response.answer.name, r'sessions/([^/]+)') AS session_id,
    jsonPayload.response.answer.state AS state,
    jsonPayload.response.assisttoken AS assist_token
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.logmetadata.methodname IN ('StreamAssist', 'Assist')
    AND ARRAY_LENGTH(jsonPayload.request.query.parts) > 0
),
redacted AS (
  SELECT * EXCEPT(prompt_raw),
    REGEXP_REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(
          REGEXP_REPLACE(prompt_raw,
            r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b', '[EMAIL]'),
          r'(?:\+?86[- ]?)?(?:1[3-9]\d{9})', '[PHONE]'),
        r'\b\d{15,18}[Xx]?\b', '[ID-NUMBER]'),
      r'\b\d{16,19}\b', '[CARD-NUMBER]'
    ) AS prompt
  FROM base
)
SELECT
  r.*,
  CASE
    WHEN r.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN r.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN r.actor_email LIKE '%@%' AND r.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  em.display_name AS engine_display_name
FROM redacted r
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em
  ON r.engine_id_raw = em.engine_id;

-- ---------------------------------------------------------------
-- v_choices — model response chunks
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_choices` AS
SELECT
  timestamp,
  trace AS trace_id,
  resource.labels.engine_id AS engine_id_raw,
  resource.labels.agent_id AS agent_id,
  jsonPayload.finish_reason AS finish_reason,
  (SELECT text FROM UNNEST(jsonPayload.content.parts) WHERE text IS NOT NULL AND (thought IS NULL OR thought = false) LIMIT 1) AS response_text,
  (SELECT text FROM UNNEST(jsonPayload.content.parts) WHERE text IS NOT NULL AND thought = true LIMIT 1) AS reasoning_text,
  ARRAY_LENGTH(jsonPayload.content.parts) AS part_count
FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gen_ai_choice`;

-- ---------------------------------------------------------------
-- v_choices_agg — group streaming chunks by trace_id
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_choices_agg` AS
SELECT
  trace_id, agent_id,
  ANY_VALUE(engine_id_raw) AS engine_id,
  MIN(timestamp) AS first_chunk_at,
  MAX(timestamp) AS last_chunk_at,
  COUNT(*) AS chunk_count,
  MAX(CASE finish_reason
    WHEN 'STOP' THEN 4 WHEN 'MAX_TOKENS' THEN 3 WHEN 'SAFETY' THEN 2
    WHEN 'FINISH_REASON_UNSPECIFIED' THEN 0 ELSE 1
  END) AS finish_score,
  STRING_AGG(response_text, '' ORDER BY timestamp) AS response_full,
  STRING_AGG(reasoning_text, '\n~~~\n' ORDER BY timestamp) AS reasoning_full,
  COUNTIF(response_text IS NOT NULL) AS response_chunk_count,
  COUNTIF(reasoning_text IS NOT NULL) AS reasoning_chunk_count
FROM `{{PROJECT}}.{{DATASET}}.v_choices`
GROUP BY trace_id, agent_id;

-- ---------------------------------------------------------------
-- v_conversations_with_response — exact trace JOIN
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_conversations_with_response` AS
SELECT
  p.timestamp, p.actor_email, p.origin,
  p.engine_id_raw, p.engine_display_name,
  p.prompt, p.session_id,
  p.trace_id AS prompt_trace_id,
  ca.trace_id AS response_trace_id,
  ca.response_full AS response_text,
  ca.reasoning_full AS reasoning_text,
  CASE ca.finish_score
    WHEN 4 THEN 'STOP' WHEN 3 THEN 'MAX_TOKENS' WHEN 2 THEN 'SAFETY'
    WHEN 1 THEN 'OTHER' WHEN 0 THEN 'UNSPECIFIED' ELSE NULL
  END AS response_status,
  ca.chunk_count,
  IF(ca.trace_id IS NOT NULL, 'matched', 'no_response') AS join_status
FROM `{{PROJECT}}.{{DATASET}}.v_conversations` p
LEFT JOIN `{{PROJECT}}.{{DATASET}}.v_choices_agg` ca
  ON ca.trace_id = p.trace_id;

-- ---------------------------------------------------------------
-- v_user_usage — per user × engine
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_user_usage` AS
WITH ua AS (
  SELECT
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(jsonPayload.logmetadata.name, r'/engines/([^/]+)') AS engine_id_raw,
    timestamp,
    jsonPayload.logmetadata.methodname AS method,
    REGEXP_EXTRACT(TO_JSON_STRING(jsonPayload.response), r'sessions/([^"\\\/]+)') AS session_id
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') IS NOT NULL
)
SELECT
  ua.actor_email,
  CASE
    WHEN ua.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN ua.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN ua.actor_email LIKE '%@%' AND ua.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  ua.engine_id_raw AS engine_id,
  em.display_name AS engine_display_name,
  COUNT(*) AS event_count,
  COUNTIF(ua.method = 'StreamAssist') AS chat_turns,
  COUNT(DISTINCT ua.session_id) AS session_count,
  MIN(ua.timestamp) AS first_seen,
  MAX(ua.timestamp) AS last_seen,
  TIMESTAMP_DIFF(MAX(ua.timestamp), MIN(ua.timestamp), DAY) AS days_active_span
FROM ua
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em ON ua.engine_id_raw = em.engine_id
GROUP BY actor_email, engine_id, engine_display_name;

-- ---------------------------------------------------------------
-- v_user_persona — 7 personas
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_user_persona` AS
WITH
  actors AS (
    SELECT actor_email FROM `{{PROJECT}}.{{DATASET}}.v_user_usage`
    UNION DISTINCT
    SELECT actor_email FROM `{{PROJECT}}.{{DATASET}}.v_admin_activity` WHERE actor_email IS NOT NULL
    UNION DISTINCT
    SELECT actor_email FROM `{{PROJECT}}.{{DATASET}}.v_data_access` WHERE actor_email IS NOT NULL
  ),
  chat AS (
    SELECT actor_email,
      SUM(chat_turns) AS chat_turns_total,
      SUM(session_count) AS sessions_total,
      SUM(IF(last_seen >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 7 DAY), chat_turns, 0)) AS chat_turns_7d,
      SUM(IF(last_seen >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 7 DAY), session_count, 0)) AS sessions_7d,
      MAX(last_seen) AS last_chat
    FROM `{{PROJECT}}.{{DATASET}}.v_user_usage` GROUP BY actor_email
  ),
  build AS (
    SELECT actor_email,
      SUM(agents_created) AS agents_c, SUM(agents_deleted) AS agents_d,
      SUM(engines_created) AS engines_c, SUM(datastores_created) AS ds_c, SUM(datastores_deleted) AS ds_d,
      MAX(last_admin_action) AS last_admin
    FROM `{{PROJECT}}.{{DATASET}}.v_builders` GROUP BY actor_email
  )
SELECT
  a.actor_email AS user,
  CASE
    WHEN a.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN a.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN a.actor_email LIKE '%@%' AND a.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  IFNULL(chat.chat_turns_total, 0) AS chat_turns_total,
  IFNULL(chat.chat_turns_7d, 0) AS chat_turns_7d,
  IFNULL(chat.sessions_total, 0) AS sessions_total,
  IFNULL(build.agents_c, 0) + IFNULL(build.engines_c, 0) + IFNULL(build.ds_c, 0) AS resources_created,
  IFNULL(build.agents_c, 0) AS agents_created,
  IFNULL(build.engines_c, 0) AS engines_created,
  IFNULL(build.ds_c, 0) AS datastores_created,
  CASE
    WHEN a.actor_email LIKE '%gserviceaccount.com' AND a.actor_email NOT LIKE '{{SIM_PATTERN}}' THEN 'AUTOMATION'
    WHEN IFNULL(build.agents_c, 0) + IFNULL(build.engines_c, 0) + IFNULL(build.ds_c, 0) >= 1 THEN 'BUILDER'
    WHEN IFNULL(chat.chat_turns_7d, 0) >= 20 AND IFNULL(chat.sessions_7d, 0) >= 3 THEN 'POWER_USER'
    WHEN IFNULL(chat.chat_turns_7d, 0) >= 5 THEN 'ACTIVE_CONSUMER'
    WHEN IFNULL(chat.chat_turns_total, 0) BETWEEN 1 AND 4 THEN 'TRIAL'
    ELSE 'LURKER'
  END AS persona,
  GREATEST(IFNULL(chat.last_chat, TIMESTAMP('1970-01-01')), IFNULL(build.last_admin, TIMESTAMP('1970-01-01'))) AS last_seen,
  LEAST(IFNULL(chat.last_chat, TIMESTAMP('9999-12-31')), IFNULL(build.last_admin, TIMESTAMP('9999-12-31'))) AS first_seen
FROM actors a
LEFT JOIN chat USING (actor_email)
LEFT JOIN build USING (actor_email);

-- ---------------------------------------------------------------
-- v_engine_adoption
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_engine_adoption` AS
WITH base AS (
  SELECT
    REGEXP_EXTRACT(jsonPayload.logmetadata.name, r'/engines/([^/]+)') AS engine_id,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    jsonPayload.logmetadata.methodname AS method,
    REGEXP_EXTRACT(TO_JSON_STRING(jsonPayload.response), r'sessions/([^"\\\/]+)') AS session_id
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
)
SELECT
  b.engine_id,
  em.display_name AS engine_display_name,
  COUNT(DISTINCT b.actor_email) AS unique_users,
  COUNTIF(b.method = 'StreamAssist') AS chat_turns,
  COUNT(DISTINCT b.session_id) AS sessions,
  COUNT(*) AS total_events
FROM base b
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em ON em.engine_id = b.engine_id
WHERE b.engine_id IS NOT NULL
GROUP BY engine_id, engine_display_name
ORDER BY total_events DESC;

-- ---------------------------------------------------------------
-- v_zero_use_seats / v_dau (simple)
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_zero_use_seats` AS
WITH all_users AS (
  SELECT REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS user_id, MIN(timestamp) AS first_seen
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') IS NOT NULL
  GROUP BY user_id
),
recent AS (
  SELECT DISTINCT REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS user_id
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE timestamp >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 14 DAY)
    AND REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') IS NOT NULL
)
SELECT a.user_id, a.first_seen, TIMESTAMP_DIFF(CURRENT_TIMESTAMP(), a.first_seen, DAY) AS days_since_first_seen
FROM all_users a
LEFT JOIN recent r USING (user_id)
WHERE r.user_id IS NULL
ORDER BY a.first_seen ASC;

CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_dau` AS
SELECT
  DATE(timestamp) AS d,
  COUNT(DISTINCT REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-')) AS dau,
  COUNT(*) AS total_events,
  COUNTIF(jsonPayload.logmetadata.methodname = 'StreamAssist') AS chat_turns
FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
WHERE REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') IS NOT NULL
GROUP BY d ORDER BY d DESC;

-- ---------------------------------------------------------------
-- v_agentspace_navigation — which GE "page" / agent did users open?
-- Source: UserEventService.WriteUserEvent with userevent.agentspaceinfo.
-- This is NAVIGATION not invocation — captures users opening Deep Research /
-- NotebookLM / custom agent detail pages.
-- Page types observed: home, agent_gallery, agent, deep-research, notebook-lm
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_agentspace_navigation` AS
WITH base AS (
  SELECT
    timestamp,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype AS page_type,
    jsonPayload.request.userevent.agentspaceinfo.agentinfo.agentid AS agent_id,
    jsonPayload.request.userevent.agentspaceinfo.agentinfo.name AS agent_name,
    REGEXP_EXTRACT(jsonPayload.request.userevent.engine, r'/engines/([^/]+)$') AS engine_id_raw
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype IS NOT NULL
    AND REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') IS NOT NULL
)
SELECT
  b.actor_email,
  CASE
    WHEN b.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN b.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN b.actor_email LIKE '%@%' AND b.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  b.page_type,
  b.agent_id,
  MAX(b.agent_name) AS agent_name,  -- GE sometimes emits NULL name; coalesce across rows
  b.engine_id_raw,
  em.display_name AS engine_display_name,
  COUNT(*) AS visits,
  MIN(b.timestamp) AS first_visit,
  MAX(b.timestamp) AS last_visit
FROM base b
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em
  ON b.engine_id_raw = em.engine_id
GROUP BY b.actor_email, b.page_type, b.agent_id, b.engine_id_raw, em.display_name
ORDER BY visits DESC;

-- ---------------------------------------------------------------
-- v_agentspace_navigation_summary — per-user pivot
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_agentspace_navigation_summary` AS
SELECT
  REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
  CASE
    WHEN REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') LIKE '%@%' AND REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  COUNTIF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'home') AS home_visits,
  COUNTIF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'agent_gallery') AS gallery_visits,
  COUNTIF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'deep-research') AS deep_research_visits,
  COUNTIF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'notebook-lm') AS notebooklm_visits,
  COUNTIF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'agent') AS custom_agent_visits,
  COUNT(DISTINCT IF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'agent',
                    jsonPayload.request.userevent.agentspaceinfo.agentinfo.agentid, NULL)) AS distinct_custom_agents,
  STRING_AGG(DISTINCT
    IF(jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'agent',
       jsonPayload.request.userevent.agentspaceinfo.agentinfo.name, NULL),
    ', ') AS custom_agent_names,
  COUNT(*) AS total_navigation_events,
  MAX(timestamp) AS last_visit
FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
WHERE jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype IS NOT NULL
  AND REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') IS NOT NULL
GROUP BY actor_email, origin
ORDER BY total_navigation_events DESC;

-- ---------------------------------------------------------------
-- v_agent_directory — agent-centric pivot: one row per known agent
-- Sources unioned:
--   1. Built-in agents inferred from data_access_summary buckets
--      (Deep Research, NotebookLM, REST Search)
--   2. Custom agents discovered via agentspace_navigation (page_type='agent')
--   3. Agents seen in gen_ai.choice (via v_agent_usage's agent_id field)
-- Each row: agent_id, agent_name, agent_type, signal_kind, total, unique_users,
-- top_user_email, last_activity, top_user_value.
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_agent_directory` AS
WITH
  -- Built-in: Deep Research, aggregated across all engines/users
  built_in_dr AS (
    SELECT
      'deep_research' AS agent_id,
      'Deep Research' AS agent_name,
      'built-in' AS agent_type,
      'api_calls' AS signal_kind,
      SUM(deep_research_calls) AS total,
      COUNT(DISTINCT IF(deep_research_calls > 0, actor_email, NULL)) AS unique_users,
      ARRAY_AGG(STRUCT(actor_email AS email, deep_research_calls AS n)
                ORDER BY deep_research_calls DESC LIMIT 1)[OFFSET(0)] AS top_user,
      MAX(IF(deep_research_calls > 0, last_access, NULL)) AS last_activity
    FROM `{{PROJECT}}.{{DATASET}}.v_data_access_summary`
    HAVING SUM(deep_research_calls) > 0
  ),
  -- Built-in: NotebookLM (all sub-services collapsed)
  built_in_nb AS (
    SELECT
      'notebooklm' AS agent_id,
      'NotebookLM' AS agent_name,
      'built-in' AS agent_type,
      'api_calls' AS signal_kind,
      SUM(notebooklm_notebook_ops + notebooklm_content_ops + notebooklm_audio_ops) AS total,
      COUNT(DISTINCT IF(notebooklm_notebook_ops + notebooklm_content_ops + notebooklm_audio_ops > 0, actor_email, NULL)) AS unique_users,
      ARRAY_AGG(STRUCT(actor_email AS email,
                       notebooklm_notebook_ops + notebooklm_content_ops + notebooklm_audio_ops AS n)
                ORDER BY notebooklm_notebook_ops + notebooklm_content_ops + notebooklm_audio_ops DESC LIMIT 1)[OFFSET(0)] AS top_user,
      MAX(IF(notebooklm_notebook_ops + notebooklm_content_ops + notebooklm_audio_ops > 0, last_access, NULL)) AS last_activity
    FROM `{{PROJECT}}.{{DATASET}}.v_data_access_summary`
    HAVING SUM(notebooklm_notebook_ops + notebooklm_content_ops + notebooklm_audio_ops) > 0
  ),
  -- Built-in: A2A invocations (rolled up across all marketplace + custom A2A agents)
  built_in_a2a AS (
    SELECT
      'a2a_protocol' AS agent_id,
      'A2A 协议调用' AS agent_name,
      'built-in' AS agent_type,
      'api_calls' AS signal_kind,
      SUM(a2a_invocations) AS total,
      COUNT(DISTINCT IF(a2a_invocations > 0, actor_email, NULL)) AS unique_users,
      ARRAY_AGG(STRUCT(actor_email AS email, a2a_invocations AS n)
                ORDER BY a2a_invocations DESC LIMIT 1)[OFFSET(0)] AS top_user,
      MAX(IF(a2a_invocations > 0, last_access, NULL)) AS last_activity
    FROM `{{PROJECT}}.{{DATASET}}.v_data_access_summary`
    HAVING SUM(a2a_invocations) > 0
  ),
  -- Custom agents from navigation (Hermes Slides etc.)
  custom_agents AS (
    SELECT
      agent_id,
      MAX(agent_name) AS agent_name,
      'custom' AS agent_type,
      'page_opens' AS signal_kind,
      SUM(visits) AS total,
      COUNT(DISTINCT actor_email) AS unique_users,
      ARRAY_AGG(STRUCT(actor_email AS email, visits AS n)
                ORDER BY visits DESC LIMIT 1)[OFFSET(0)] AS top_user,
      MAX(last_visit) AS last_activity
    FROM `{{PROJECT}}.{{DATASET}}.v_agentspace_navigation`
    WHERE page_type = 'agent' AND agent_id IS NOT NULL
    GROUP BY agent_id
  )
SELECT
  agent_id, agent_name, agent_type, signal_kind, total, unique_users,
  top_user.email AS top_user_email, top_user.n AS top_user_value,
  last_activity
FROM (
  SELECT * FROM built_in_dr
  UNION ALL SELECT * FROM built_in_nb
  UNION ALL SELECT * FROM built_in_a2a
  UNION ALL SELECT * FROM custom_agents
)
ORDER BY total DESC;

-- ---------------------------------------------------------------
-- v_deep_research_prompts — reverse-attribute prompts to Deep Research
-- Heuristic: for each AsyncAssist/ReadAsyncAssist audit event, find the
-- nearest StreamAssist prompt from the SAME actor within ±60s.
-- The UI groups by prompt to show "these DR events all came from this query".
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_deep_research_prompts` AS
WITH dr_events AS (
  SELECT
    timestamp AS dr_ts,
    REGEXP_REPLACE(protopayload_auditlog.authenticationInfo.principalEmail, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(protopayload_auditlog.methodName, r'\.([^.]+)$') AS dr_action
  FROM `{{PROJECT}}.{{DATASET}}.cloudaudit_googleapis_com_data_access`
  WHERE protopayload_auditlog.methodName LIKE '%AssistantService.AsyncAssist'
     OR protopayload_auditlog.methodName LIKE '%AssistantService.ReadAsyncAssist'
),
stream_prompts AS (
  SELECT
    timestamp AS prompt_ts,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(jsonPayload.request.name, r'/engines/([^/]+)/') AS engine_id_raw,
    (SELECT text FROM UNNEST(jsonPayload.request.query.parts) WHERE text IS NOT NULL LIMIT 1) AS prompt
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.logmetadata.methodname = 'StreamAssist'
    AND ARRAY_LENGTH(jsonPayload.request.query.parts) > 0
),
-- For each DR event, pick the closest prompt (may be NULL if none within ±60s)
attributed AS (
  SELECT
    dr.dr_ts,
    dr.dr_action,
    dr.actor_email,
    ARRAY_AGG(STRUCT(sp.prompt_ts, sp.prompt, sp.engine_id_raw,
                     ABS(TIMESTAMP_DIFF(sp.prompt_ts, dr.dr_ts, SECOND)) AS delta)
              ORDER BY ABS(TIMESTAMP_DIFF(sp.prompt_ts, dr.dr_ts, SECOND)) ASC LIMIT 1
    )[SAFE_OFFSET(0)] AS best
  FROM dr_events dr
  LEFT JOIN stream_prompts sp
    ON sp.actor_email = dr.actor_email
    AND ABS(TIMESTAMP_DIFF(sp.prompt_ts, dr.dr_ts, SECOND)) <= 60
  GROUP BY dr.dr_ts, dr.dr_action, dr.actor_email
)
SELECT
  a.dr_ts,
  a.dr_action,
  a.actor_email,
  CASE
    WHEN a.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN a.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN a.actor_email LIKE '%@%' AND a.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  a.best.prompt AS attributed_prompt,
  a.best.prompt_ts AS prompt_ts,
  a.best.delta AS attribution_delta_sec,
  a.best.engine_id_raw AS engine_id_raw,
  em.display_name AS engine_display_name
FROM attributed a
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em
  ON a.best.engine_id_raw = em.engine_id
ORDER BY a.dr_ts DESC;

-- ---------------------------------------------------------------
-- v_custom_agent_prompts — reverse-attribute chats to custom agents
-- Heuristic: when a user opens a custom agent's detail page
-- (agentspacepagetype='agent'), attribute the next 5 minutes of
-- StreamAssist chats to that agent.
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_custom_agent_prompts` AS
WITH agent_opens AS (
  SELECT
    timestamp AS open_ts,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    jsonPayload.request.userevent.agentspaceinfo.agentinfo.agentid AS agent_id,
    jsonPayload.request.userevent.agentspaceinfo.agentinfo.name AS agent_name
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.request.userevent.agentspaceinfo.agentspacepagetype = 'agent'
    AND jsonPayload.request.userevent.agentspaceinfo.agentinfo.agentid IS NOT NULL
),
stream_prompts AS (
  SELECT
    timestamp AS prompt_ts,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    REGEXP_EXTRACT(jsonPayload.request.name, r'/engines/([^/]+)/') AS engine_id_raw,
    (SELECT text FROM UNNEST(jsonPayload.request.query.parts) WHERE text IS NOT NULL LIMIT 1) AS prompt
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.logmetadata.methodname = 'StreamAssist'
    AND ARRAY_LENGTH(jsonPayload.request.query.parts) > 0
),
-- For each prompt, find the NEAREST preceding agent-open within 5 min
attributed AS (
  SELECT
    sp.prompt_ts,
    sp.prompt,
    sp.actor_email,
    sp.engine_id_raw,
    ARRAY_AGG(STRUCT(ao.agent_id, ao.agent_name, ao.open_ts,
                     TIMESTAMP_DIFF(sp.prompt_ts, ao.open_ts, SECOND) AS elapsed_sec)
              ORDER BY ao.open_ts DESC LIMIT 1
    )[SAFE_OFFSET(0)] AS best
  FROM stream_prompts sp
  JOIN agent_opens ao
    ON ao.actor_email = sp.actor_email
    AND ao.open_ts <= sp.prompt_ts
    AND TIMESTAMP_DIFF(sp.prompt_ts, ao.open_ts, SECOND) <= 300
  GROUP BY sp.prompt_ts, sp.prompt, sp.actor_email, sp.engine_id_raw
)
SELECT
  a.prompt_ts,
  a.actor_email,
  CASE
    WHEN a.actor_email LIKE '{{SIM_PATTERN}}' THEN 'SIMULATED'
    WHEN a.actor_email LIKE '%gserviceaccount.com' THEN 'AUTOMATION'
    WHEN a.actor_email LIKE '%@%' AND a.actor_email NOT LIKE '%gserviceaccount.com' THEN 'HUMAN'
    ELSE 'UNKNOWN'
  END AS origin,
  a.best.agent_id AS agent_id,
  a.best.agent_name AS agent_name,
  a.best.open_ts AS agent_open_ts,
  a.best.elapsed_sec AS elapsed_since_open_sec,
  a.prompt,
  a.engine_id_raw,
  em.display_name AS engine_display_name
FROM attributed a
LEFT JOIN `{{PROJECT}}.{{DATASET}}.engine_metadata` em
  ON a.engine_id_raw = em.engine_id
ORDER BY a.prompt_ts DESC;

-- ---------------------------------------------------------------
-- v_daily_usage_per_user — per (user × day-in-California × feature) counts
-- Daily buckets are relative to America/Los_Angeles (GE quota resets at PT midnight).
-- BigQuery auto-handles PST/PDT via DATE(ts, 'America/Los_Angeles').
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_daily_usage_per_user` AS
WITH audit AS (
  SELECT
    DATE(timestamp, 'America/Los_Angeles') AS d,
    REGEXP_REPLACE(protopayload_auditlog.authenticationInfo.principalEmail, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    protopayload_auditlog.methodName AS method,
    protopayload_auditlog.serviceName AS service
  FROM `{{PROJECT}}.{{DATASET}}.cloudaudit_googleapis_com_data_access`
  WHERE protopayload_auditlog.authenticationInfo.principalEmail IS NOT NULL
),
admin AS (
  SELECT
    DATE(timestamp, 'America/Los_Angeles') AS d,
    REGEXP_REPLACE(protopayload_auditlog.authenticationInfo.principalEmail, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    protopayload_auditlog.methodName AS method
  FROM `{{PROJECT}}.{{DATASET}}.cloudaudit_googleapis_com_activity`
  WHERE protopayload_auditlog.authenticationInfo.principalEmail IS NOT NULL
),
combined AS (
  -- chat: StreamAssist
  SELECT d, actor_email, 'chat' AS feature, COUNT(*) AS n
  FROM audit WHERE method LIKE '%AssistantService.StreamAssist' OR method LIKE '%AssistantService.Assist'
  GROUP BY d, actor_email
  UNION ALL
  -- deep_research: AsyncAssist (submit only; ReadAsyncAssist polls not counted)
  SELECT d, actor_email, 'deep_research' AS feature, COUNTIF(method LIKE '%AssistantService.AsyncAssist')
  FROM audit WHERE method LIKE '%AsyncAssist'
  GROUP BY d, actor_email
  UNION ALL
  -- notebooklm: count only user-initiated WRITE actions, not UI page-load
  -- reads. A single "open notebook + add sources + generate audio" flow can
  -- trigger 20+ Get/List/Batch reads behind the scenes; those don't reflect
  -- what the user perceived as "actions". So we count:
  --   Create*/Update*/Delete*  (explicit mutations)
  --   Generate*                (long-running generation jobs)
  -- and exclude Get/List/Batch*Get/Discover/GetOrCreateAccount.
  SELECT d, actor_email, 'notebooklm' AS feature, COUNT(*) AS n
  FROM audit
  WHERE method LIKE '%notebooklm.%'
    AND (REGEXP_CONTAINS(method, r'\.(Create|Update|Delete|BatchCreate|BatchDelete|BatchUpdate)[A-Z]')
         OR REGEXP_CONTAINS(method, r'\.Generate[A-Z]'))
  GROUP BY d, actor_email
  UNION ALL
  -- a2a: agent-to-agent invocations
  SELECT d, actor_email, 'a2a' AS feature, COUNT(*) AS n
  FROM audit WHERE method LIKE '%assistants.agents.a2a.v1.%'
  GROUP BY d, actor_email
  UNION ALL
  -- video_gen: (a) aiplatform veo audit events if any, PLUS (b) prompt-intent
  -- heuristic: StreamAssist prompts asking for a video. GE image/video generation
  -- backend runs inside Google's infra and does NOT emit customer audit logs,
  -- so intent-detection from the user's prompt is the best signal we have.
  SELECT d, actor_email, 'video_gen' AS feature, COUNT(*) AS n
  FROM audit WHERE service = 'aiplatform.googleapis.com'
    AND (LOWER(method) LIKE '%veo%' OR LOWER(method) LIKE '%videogeneration%')
  GROUP BY d, actor_email
  UNION ALL
  SELECT
    DATE(timestamp, 'America/Los_Angeles') AS d,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    'video_gen' AS feature,
    COUNT(*) AS n
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.logmetadata.methodname = 'StreamAssist'
    AND REGEXP_CONTAINS(
      ARRAY_TO_STRING(ARRAY(SELECT text FROM UNNEST(jsonPayload.request.query.parts) WHERE text IS NOT NULL), ' '),
      r'(?i)(生成|画|绘制|制作|做一?[个只段]|来一?[个只段]|generate|make|create|draw|render)[^\n]{0,15}(视频|video|电影|movie|clip|片段|动画)'
    )
    AND jsonPayload.useriamprincipal IS NOT NULL
  GROUP BY d, actor_email
  UNION ALL
  -- image_gen: aiplatform imagen events + prompt-intent heuristic
  SELECT d, actor_email, 'image_gen' AS feature, COUNT(*) AS n
  FROM audit WHERE service = 'aiplatform.googleapis.com'
    AND (LOWER(method) LIKE '%imagen%' OR LOWER(method) LIKE '%imagegeneration%')
  GROUP BY d, actor_email
  UNION ALL
  SELECT
    DATE(timestamp, 'America/Los_Angeles') AS d,
    REGEXP_REPLACE(jsonPayload.useriamprincipal, r'^{{SIM_PREFIX}}', 'demo-') AS actor_email,
    'image_gen' AS feature,
    COUNT(*) AS n
  FROM `{{PROJECT}}.{{DATASET}}.discoveryengine_googleapis_com_gemini_enterprise_user_activity`
  WHERE jsonPayload.logmetadata.methodname = 'StreamAssist'
    AND REGEXP_CONTAINS(
      ARRAY_TO_STRING(ARRAY(SELECT text FROM UNNEST(jsonPayload.request.query.parts) WHERE text IS NOT NULL), ' '),
      r'(?i)(生成|画|绘制|来一?[张幅副个只]|generate|draw|create|render|make)[^\n]{0,20}(图|picture|image|photo|头像|封面|logo|海报|插画|帅哥|美女|风景|动物|青蛙|猫|狗|人物|漫画|卡通|贴纸|表情|图标|icon|头像)'
    )
    AND jsonPayload.useriamprincipal IS NOT NULL
  GROUP BY d, actor_email
  UNION ALL
  -- agent_create: AgentService.CreateAgent (from admin_activity)
  SELECT d, actor_email, 'agent_create' AS feature, COUNT(*) AS n
  FROM admin WHERE method LIKE '%AgentService.CreateAgent'
  GROUP BY d, actor_email
)
SELECT
  d, actor_email, feature, n
FROM combined
WHERE n > 0
ORDER BY d DESC, actor_email, feature;

-- ---------------------------------------------------------------
-- v_quota_utilization — today's usage vs each user's tier limit
-- Uses California "today" (DATE(NOW, 'America/Los_Angeles'))
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_quota_utilization` AS
WITH cfg AS (
  SELECT key, value FROM `{{PROJECT}}.{{DATASET}}.quota_config`
),
today_bucket AS (
  SELECT DATE(CURRENT_TIMESTAMP(), 'America/Los_Angeles') AS today
),
tier_limits AS (
  -- Pivot config into a lookup: (tier, feature) -> limit
  SELECT
    SPLIT(key, '.')[SAFE_OFFSET(1)] AS tier,
    REGEXP_EXTRACT(key, r'\.([^.]+)_daily$') AS feature,
    CAST(value AS INT64) AS daily_limit
  FROM cfg
  WHERE key LIKE 'tier.%_daily'
),
default_tier AS (
  SELECT value AS t FROM cfg WHERE key = 'quota.default_tier'
),
today_usage AS (
  SELECT actor_email, feature, n AS used
  FROM `{{PROJECT}}.{{DATASET}}.v_daily_usage_per_user`, today_bucket
  WHERE d = today_bucket.today
)
SELECT
  ut.actor_email,
  COALESCE(t.tier, (SELECT t FROM default_tier)) AS tier,
  tl.feature,
  tl.daily_limit,
  IFNULL(tu.used, 0) AS used_today,
  IFNULL(tu.used, 0) / tl.daily_limit AS utilization,
  IFNULL(tu.used, 0) >= tl.daily_limit AS over_quota
FROM (SELECT DISTINCT actor_email FROM `{{PROJECT}}.{{DATASET}}.user_tier`
      UNION DISTINCT
      SELECT DISTINCT actor_email FROM `{{PROJECT}}.{{DATASET}}.v_data_access_summary`
      WHERE actor_email IS NOT NULL) ut
LEFT JOIN `{{PROJECT}}.{{DATASET}}.user_tier` t USING (actor_email)
CROSS JOIN tier_limits tl
LEFT JOIN today_usage tu
  ON tu.actor_email = ut.actor_email AND tu.feature = tl.feature
WHERE tl.tier = COALESCE(t.tier, (SELECT t FROM default_tier))
ORDER BY utilization DESC, ut.actor_email, tl.feature;

-- ---------------------------------------------------------------
-- v_quota_totals — today's platform-wide usage vs sum(per-user tier limit)
-- Useful for "we bought N seats × 10 DR/day = 10N DR quota; today's actual = M"
-- ---------------------------------------------------------------
CREATE OR REPLACE VIEW `{{PROJECT}}.{{DATASET}}.v_quota_totals` AS
SELECT
  feature,
  COUNT(DISTINCT actor_email) AS eligible_users,
  SUM(daily_limit) AS total_daily_quota,
  SUM(used_today) AS total_used_today,
  SAFE_DIVIDE(SUM(used_today), SUM(daily_limit)) AS overall_utilization,
  COUNTIF(over_quota) AS users_over_quota
FROM `{{PROJECT}}.{{DATASET}}.v_quota_utilization`
GROUP BY feature
ORDER BY overall_utilization DESC;
